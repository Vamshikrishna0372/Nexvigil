# ============================================================
# Nexvigil Backend - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.

# ── Core ─────────────────────────────────────────────────────
APP_NAME=Nexvigil
ENVIRONMENT=development   # change to "production" when deploying

# ── Database ─────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/nexvigil

# ── Security ─────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-strong-random-secret-key
INTERNAL_API_KEY=change-me-to-internal-api-key

# ── NGROK Tunnel (update every time ngrok restarts) ──────────
# Run: ngrok http 8000
# Copy the "Forwarding" HTTPS URL here (no trailing slash)
NGROK_URL=https://YOUR-NGROK-ID.ngrok-free.app

# ── Vercel Frontend URL ───────────────────────────────────────
# Your deployed Vercel URL (no trailing slash)
FRONTEND_URL=https://YOUR-APP.vercel.app

# ── Email / SMTP ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=noreply@nexvigil.com

# ── Media ────────────────────────────────────────────────────
MEDIA_DIR=media

# ── Rate Limits ──────────────────────────────────────────────
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_ALERTS=60/minute
RATE_LIMIT_ANALYTICS=100/minute
