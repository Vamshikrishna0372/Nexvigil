# ============================================================
# Nexvigil Frontend - Environment Variables
# ============================================================
# For LOCAL development: copy this to .env.local
# For VERCEL deployment: add these in Vercel dashboard → Settings → Environment Variables

# Backend API base URL.
# - Local dev:      http://localhost:8000/api/v1
# - Via ngrok:      https://YOUR-NGROK-ID.ngrok-free.app/api/v1
# Update this EVERY TIME your ngrok URL changes.
VITE_API_BASE_URL=https://YOUR-NGROK-ID.ngrok-free.app/api/v1
